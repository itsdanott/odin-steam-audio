inputs = [
	"../steamaudio/include/phonon.h"
]
output_folder = ".."
imports_file = "imports.odin"
package_name = "steamaudio"
remove_type_prefix = "IPL"
remove_macro_prefix = "IPL"
remove_function_prefix = "ipl"
force_ada_case_types = true
type_overrides = {
    "IPLVector3" = "[3]f32",
    "IPLMatrix4x4" = "matrix[4,4]f32"
}